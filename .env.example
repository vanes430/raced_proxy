# Raced Proxy — Environment Configuration
# Copy this file to .env and adjust as needed.

# Rotator
LISTEN_PORT=8090
RACE=15
STAGGER=0
AUTH_USER=
AUTH_PASS=
WINNER_TTL=0
WINNER_COOLDOWN=0
MAX_LATENCY=0

# Scanner
SCAN_TARGET=opencode.ai
SOURCE_FILE=url-list.txt
REQUEST_TIMEOUT=1500
PROXY_FILE=proxy.txt
WORKER_COUNT=1000
ARCHIVE_DIR=proxy_bekas

# Model (big-pickle, mimo-v2.5-free, deepseek-v4-flash-free)
MODEL_NAME=mimo-v2.5-free
